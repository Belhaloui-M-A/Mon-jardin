# Copier ce fichier en `.env` et renseigner des valeurs réelles.
# `.env` n'est JAMAIS versionné (voir .gitignore).

# ===== Base de données =====
POSTGRES_DB=plantverde
POSTGRES_USER=plantverde
POSTGRES_PASSWORD=change_me

# ===== JWT (256 bits minimum chacun, distincts) =====
# Générer p.ex. avec : openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_access_secret_at_least_256_bits
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_256_bits_distinct

# ===== Cookies =====
# true en production (HTTPS obligatoire), false en local HTTP
COOKIE_SECURE=false

# ===== CORS (origines autorisées, séparées par des virgules) =====
CORS_ORIGINS=http://localhost:4200,http://localhost
